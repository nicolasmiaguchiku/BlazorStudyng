@page "/"
@rendermode InteractiveServer
@inject AppState AppState

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

<input type="text" placeholder="Digite um nome" @bind="name" />
<button type="submit" @onclick="SubmitName">Enviar nome</button>

<Component1 Name="@AppState.Name" />

Welcome to your new app.

@code {
    private string name = string.Empty;

    public void SubmitName()
    {
        AppState.Name = name;
    }
}